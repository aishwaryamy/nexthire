# Required
OPENAI_API_KEY=sk-...

# Optional — Claude as alternative LLM
ANTHROPIC_API_KEY=sk-ant-...

# Optional — contact finder (free tier: 25 searches/month)
HUNTER_API_KEY=

# Optional — web search for job discovery
SERPER_API_KEY=

# App password (leave empty to disable)
APP_PASSWORD=

# Database (SQLite default, override for Postgres)
DATABASE_URL=sqlite:///./jobhunt.db

# Redis (optional)
REDIS_URL=redis://localhost:6379
